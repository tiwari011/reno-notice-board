generator client {
  provider = "prisma-client-js"
  
}

datasource db {
  provider = "postgresql"
}

enum NoticeCategory {
  EXAM
  EVENT
  GENERAL
}

enum NoticePriority {
  NORMAL
  URGENT
}

model Notice {
  id          String          @id @default(cuid())
  title       String
  body        String
  category    NoticeCategory
  priority    NoticePriority  @default(NORMAL)
  publishDate DateTime
  image       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([priority, publishDate])
  @@index([publishDate])
}
